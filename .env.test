# ── PostgreSQL ───────────────────────────────────────────────
DB_NAME=wohnungsbot
DB_USER=your_db_user
DB_PASS=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_POSTGRES=postgres

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Scraping ─────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=240
NOTIFICATION_DELAY=3.0
REQUEST_TIMEOUT=15
REQUEST_DELAY=2.0
MAX_RETRIES=3

# ── App ───────────────────────────────────────────────────────
ENGINE_DEBUG=false