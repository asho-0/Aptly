# ── PostgreSQL ───────────────────────────────────────────────
DB_NAME=database_name
DB_USER=user_name
DB_PASS=secret_password
DB_HOST=localhost
DB_PORT=5432
DB_POSTGRES=postgres

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=some_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Scraping ─────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT=15
REQUEST_DELAY=2.0
MAX_RETRIES=3

# ── App ───────────────────────────────────────────────────────
ENGINE_DEBUG=false
LOG_LEVEL=INFO
BOT_LANGUAGE=en

# ── Default apartment filters ────────────────────────────────
FILTER_MIN_ROOMS=1
FILTER_MAX_ROOMS=4
FILTER_MIN_SQM=30
FILTER_MAX_SQM=120
FILTER_MIN_PRICE=400
FILTER_MAX_PRICE=2000
FILTER_SOCIAL_STATUS=any
