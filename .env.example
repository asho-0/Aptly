# ============================================================
# .env.example — copy to .env and fill in your values
# Never commit the real .env to version control!
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DB_NAME=wohnungsbot
DB_USER=wohnungsbot
DB_PASS=supersecretpassword
DB_HOST=localhost
DB_PORT=5432

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz-example
TELEGRAM_CHAT_ID=987654321

# ── Scraping ─────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60
REQUEST_TIMEOUT=15
REQUEST_DELAY=2.0

# ── App ───────────────────────────────────────────────────────
ENGINE_DEBUG=false
LOG_LEVEL=INFO
BOT_LANGUAGE=de

# ── Default apartment filters ────────────────────────────────
FILTER_MIN_ROOMS=1
FILTER_MAX_ROOMS=4
FILTER_MIN_SQM=30
FILTER_MAX_SQM=120
FILTER_MIN_PRICE=400
FILTER_MAX_PRICE=2000
FILTER_SOCIAL_STATUS=any
FILTER_EXCLUDE_KEYWORDS=gewerbe,büro,garage,lager,praxis
FILTER_INCLUDE_KEYWORDS=

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=              # uncomment if auth is enabled

# TTL for seen listing IDs in Redis (seconds). Default = 30 days.
REDIS_SEEN_TTL=2592000
